# KF RoleLogger configuration. Copy to `.env` and fill in real values.
# .env is gitignored — never commit real secrets.

DISCORD_TOKEN=your_kf_role_logger_bot_token_here
GUILD_ID=1498857206651555962

# Permission roles on KF Japanese Lab guild (public IDs)
ROLE_NEWCOMER=1498862867284234311
ROLE_MEMBER=1498862749927608473

# Days a Newcomer must wait before auto-promotion to Member.
# Production value is fixed at 7. Override only via shell env for short-cycle tests
# (e.g. `$env:PROMOTION_GRACE_DAYS="0.001"; .venv\Scripts\python main.py`).
PROMOTION_GRACE_DAYS=7
